/* pages/profile/profile.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.user-section {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 30rpx;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.openid {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.couple-section {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-status {
  font-size: 24rpx;
  color: #1AAD19;
}

.bound-info {
  text-align: center;
}

.partner-info {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.partner-info image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.bind-time {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-unbind {
  background: #FA5151;
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
}

.unbind-actions {
  text-align: center;
}

.btn-primary {
  background: #1AAD19;
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}

.divider {
  font-size: 28rpx;
  color: #999;
  margin: 30rpx 0;
}

.join-section {
  text-align: center;
}

.bind-input {
  width: 60%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.btn-secondary {
  background: #007AFF;
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  margin: 20rpx;
}

.btn-generate {
  background: #FF9500;
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx 40rpx;
  font-size: 30rpx;
  margin: 20rpx;
}

.features-section {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
}

.feature-item {
  background: #f8f8f8;
  border-radius: 10rpx;
  padding: 30rpx 10rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

/* 适配不同屏幕尺寸 */
@media screen and (max-width: 375px) {
  .feature-grid {
    grid-template-columns: 1fr 1fr;
  }
}