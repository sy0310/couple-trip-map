/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #FF6B81 0%, #FF8E53 100%);
  color: #ffffff;
}

.stats-header {
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
}

.stats-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
  display: block;
}

.stats-content {
  padding: 20rpx 0;
}

.stat-item {
  flex: 1;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  color: #ffffff;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
  display: block;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
  margin: 0 20rpx;
}

/* 地图卡片 */
.map-card {
  margin-top: 20rpx;
}

.map-header {
  margin-bottom: 20rpx;
}

.map-title {
  font-size: 32rpx;
  font-weight: 600;
}

.map-action {
  font-size: 28rpx;
}

.map-placeholder {
  height: 600rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.map-tip {
  position: absolute;
  color: #999;
  font-size: 28rpx;
  z-index: 10;
}

.map-image {
  width: 100%;
  height: 100%;
}

/* 最近旅行 */
.recent-card {
  margin-top: 20rpx;
}

.card-header {
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
}

.card-more {
  font-size: 24rpx;
}

.recent-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.recent-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.recent-location {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.recent-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.recent-count {
  font-size: 24rpx;
  color: #FF6B81;
}
