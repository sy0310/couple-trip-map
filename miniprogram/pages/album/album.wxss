/* pages/album/album.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  position: relative;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.btn-add {
  background: #1AAD19;
  color: white;
  border: none;
  border-radius: 10rpx;
  padding: 15rpx 30rpx;
  font-size: 28rpx;
}

.years-selector {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.years-scroll {
  white-space: nowrap;
}

.years-container {
  display: inline-flex;
}

.year-item {
  padding: 15rpx 25rpx;
  margin-right: 20rpx;
  background: #f0f0f0;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.year-item.selected {
  background: #1AAD19;
  color: white;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  font-size: 28rpx;
  color: #999;
}

.album-content {
  min-height: 600rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.albums-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300rpx, 1fr));
  gap: 25rpx;
}

.album-item {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.album-cover {
  position: relative;
  height: 200rpx;
  overflow: hidden;
}

.album-cover image {
  width: 100%;
  height: 100%;
}

.album-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  color: white;
  padding: 30rpx 20rpx 20rpx;
}

.album-location {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.album-date {
  display: block;
  font-size: 20rpx;
  opacity: 0.8;
}

.album-info {
  padding: 20rpx;
}

.album-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.album-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.timeline-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.timeline {
  position: relative;
  padding-left: 40rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: #e0e0e0;
}

.timeline-item {
  position: relative;
  margin-bottom: 50rpx;
  padding-left: 40rpx;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: -54rpx;
  top: 10rpx;
  width: 16rpx;
  height: 16rpx;
  background: #1AAD19;
  border-radius: 50%;
  border: 6rpx solid white;
  box-shadow: 0 0 0 2rpx #1AAD19;
}

.timeline-date {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 15rpx;
}

.timeline-content {
  background: #f8f9fa;
  padding: 25rpx;
  border-radius: 15rpx;
}

.timeline-location {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.timeline-notes {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.timeline-photos {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 20rpx;
}

.photo-wrapper {
  position: relative;
  aspect-ratio: 1;
  border-radius: 10rpx;
  overflow: hidden;
}

.timeline-photo {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
}

.empty-state {
  text-align: center;
  padding: 200rpx 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.refresh-btn {
  position: fixed;
  right: 40rpx;
  bottom: 100rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1AAD19;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
  z-index: 100;
}

/* 适配小屏幕 */
@media screen and (max-width: 375px) {
  .albums-grid {
    grid-template-columns: 1fr;
  }
  
  .timeline-photos {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .header {
    flex-direction: column;
    gap: 20rpx;
  }
  
  .title {
    font-size: 40rpx;
  }
}